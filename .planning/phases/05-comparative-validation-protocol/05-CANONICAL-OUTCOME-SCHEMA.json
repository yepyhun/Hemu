  "comparison_outcome_required_fields": [
    "phase",
    "baseline_artifact",
    "hybrid_artifact",
    "verdict",
    "verdict_precedence_applied",
    "verdict_reason",
    "locked_thresholds",
    "baseline",
    "hybrid",
    "delta",
